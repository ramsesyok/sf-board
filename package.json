{
  "name": "sf-board",
  "displayName": "SF Board",
  "description": "エアギャップ環境向けサーバレス・ボード(共有ネットワークフォルダのみで動作)",
  "version": "0.0.5",
  "publisher": "airgap",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "l10n": "./l10n",
  "activationEvents": [
    "onView:sfBoardChannels"
  ],
  "scripts": {
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && tsc --noEmit -p src/ui/webview/tsconfig.json",
    "vscode:prepublish": "npm run build",
    "package": "vsce package --allow-missing-repository"
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "sfBoard",
          "title": "%viewContainer.sfBoard%",
          "icon": "media/chat.svg"
        }
      ]
    },
    "views": {
      "sfBoard": [
        {
          "id": "sfBoardChannels",
          "name": "%view.channels%"
        }
      ]
    },
    "commands": [
      {
        "command": "sfBoard.openChannel",
        "title": "%command.openChannel%",
        "category": "SF Board"
      },
      {
        "command": "sfBoard.createChannel",
        "title": "%command.createChannel%",
        "category": "SF Board",
        "icon": "$(add)"
      },
      {
        "command": "sfBoard.renameChannel",
        "title": "%command.renameChannel%",
        "category": "SF Board"
      },
      {
        "command": "sfBoard.refresh",
        "title": "%command.refresh%",
        "category": "SF Board",
        "icon": "$(refresh)"
      },
      {
        "command": "sfBoard.setup",
        "title": "%command.setup%",
        "category": "SF Board"
      },
      {
        "command": "sfBoard.showDiagnostics",
        "title": "%command.showDiagnostics%",
        "category": "SF Board"
      },
      {
        "command": "sfBoard.verifyConnection",
        "title": "%command.verifyConnection%",
        "category": "SF Board"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "sfBoard.createChannel",
          "when": "view == sfBoardChannels",
          "group": "navigation@1"
        },
        {
          "command": "sfBoard.refresh",
          "when": "view == sfBoardChannels",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "sfBoard.renameChannel",
          "when": "view == sfBoardChannels && viewItem == channel",
          "group": "inline"
        }
      ],
      "commandPalette": [
        {
          "command": "sfBoard.openChannel",
          "when": "false"
        },
        {
          "command": "sfBoard.renameChannel",
          "when": "false"
        }
      ]
    },
    "configuration": {
      "title": "SF Board",
      "properties": {
        "sfBoard.rootPath": {
          "type": "string",
          "default": "",
          "markdownDescription": "%config.rootPath%"
        },
        "sfBoard.userId": {
          "type": "string",
          "default": "",
          "markdownDescription": "%config.userId%"
        },
        "sfBoard.displayName": {
          "type": "string",
          "default": "",
          "markdownDescription": "%config.displayName%"
        },
        "sfBoard.poll.reconcileSec": {
          "type": "number",
          "default": 90,
          "markdownDescription": "%config.poll.reconcileSec%"
        },
        "sfBoard.poll.fallbackSec": {
          "type": "number",
          "default": 4,
          "markdownDescription": "%config.poll.fallbackSec%"
        },
        "sfBoard.watch.enabled": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%config.watch.enabled%"
        },
        "sfBoard.attachmentMaxBytes": {
          "type": "number",
          "default": 10485760,
          "markdownDescription": "%config.attachmentMaxBytes%"
        },
        "sfBoard.imageInlinePreview": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%config.imageInlinePreview%"
        },
        "sfBoard.threadDisplay": {
          "type": "string",
          "enum": [
            "inline",
            "thread"
          ],
          "enumDescriptions": [
            "%config.threadDisplay.inline%",
            "%config.threadDisplay.thread%"
          ],
          "default": "inline",
          "markdownDescription": "%config.threadDisplay%"
        },
        "sfBoard.diagnostics.enabled": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "%config.diagnostics.enabled%"
        },
        "sfBoard.confirmOpenPath": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%config.confirmOpenPath%"
        }
      }
    }
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^20.11.0",
    "@types/vscode": "1.85.0",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.20.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "@vscode/markdown-it-katex": "^1.1.2",
    "dompurify": "^3.4.11",
    "highlight.js": "^11.11.1",
    "katex": "^0.17.0",
    "markdown-it": "^14.3.0",
    "mermaid": "^11.16.0"
  }
}
